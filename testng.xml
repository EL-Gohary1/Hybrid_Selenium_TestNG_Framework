<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite">
    <listeners>
        <listener class-name="com.tutorialsninja.listeners.MyListeners" />
    </listeners>
    <test verbose="2" name="E:/iti/Selenium_TestNG_Framework">
        <classes>
            <class name="com.tutorialsninja.tests.LoginTests">
                <methods>
                    <include name="verifyLoggingUsingValidCredentialTest"/>
                </methods>
            </class>
            <class name="com.tutorialsninja.tests.RegisterTests">
                <methods>
                    <include name="verifyRegisteringByProvidingOnlyMandatoryFields"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>